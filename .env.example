OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Body Vision
OPENROUTER_SITE_URL=http://localhost:9000
FAL_KEY=

EXTRACTION_PROVIDER=gemini
GENERATION_PROVIDER=gemini
VALIDATION_PROVIDER=gemini

GEMINI_VLM_MODEL=google/gemini-3.1-pro-preview
GEMINI_GENERATION_MODEL=google/gemini-3-pro-image-preview

GPT_VLM_MODEL=openai/gpt-5.4-image-2
GPT_GENERATION_MODEL=openai/gpt-5.4-image-2

RETRY_MAX_ATTEMPTS=3

# Sapiens align pipeline (external service; wired in later steps)
SAPIENS_BASE_URL=http://localhost:8001
SAPIENS_SEGMENTATION_PATH=/api/segmentation
ALIGN_CANVAS_SIZE=2000
ALIGN_PIXELS_PER_CM=10
ALIGN_CANVAS_PATH=assets/standardization-image.png
